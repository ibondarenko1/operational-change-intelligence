POSTGRES_DB=oci
POSTGRES_USER=oci
POSTGRES_PASSWORD=oci_password
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=postgresql+psycopg://oci:oci_password@db:5432/oci
APP_CHECK_DB_ON_STARTUP=true
DB_CONNECT_TIMEOUT_SECONDS=3
DEMO_MODE=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
